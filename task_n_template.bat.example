@echo off
setlocal EnableDelayedExpansion
title Launch Custom Task

REM ========================================================
REM CONFIGURATION REQUIRED
REM 1. Rename this file (e.g., task_5_custom.bat)
REM 2. Set the directory path where your program is installed
REM 3. Set the executable file name
REM 4. (Optional) Add any startup arguments
REM ========================================================

echo [%time%] [Task N] Launching Custom Application...

set "APP_DIR=YOUR_INSTALLATION_PATH_HERE"
set "APP_EXE=YourProgram.exe"
set "APP_ARGS="
REM Example with arguments: set "APP_ARGS=-silent -minimize"

set "APP_PATH=!APP_DIR!\!APP_EXE!"

if exist "!APP_PATH!" (
    echo Starting application...
    
    REM 'pushd' ensures the program starts in its own directory (important for some apps)
    pushd "!APP_DIR!"
    
    REM Start the program without waiting for it to close
    start "" "!APP_EXE!" !APP_ARGS!
    
    if !errorlevel!==0 (
        echo [%time%] Application started successfully.
    ) else (
        echo [%time%] [ERROR] Failed to start application, error code: !errorlevel!
        popd
        exit /b 1
    )
    popd
) else (
    echo [%time%] [ERROR] File not found: "!APP_PATH!"
    echo Please check the installation path in this script.
    exit /b 1
)

exit /b 0