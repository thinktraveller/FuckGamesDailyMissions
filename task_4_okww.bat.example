@echo off
setlocal EnableDelayedExpansion
title Launch ok-ww

echo [%time%] [Task 4/4] Launching ok-ww.exe (Parameter: -t 1 -e)
REM ========================================================
REM CONFIGURATION REQUIRED
REM Please set APP_DIR to the directory where ok-ww.exe is installed.
REM Example: set "APP_DIR=E:\Games\ok-ww"
REM ========================================================
set "APP_DIR=YOUR_INSTALLATION_PATH_HERE"
set "APP_EXE=ok-ww.exe"
set "APP_PATH=!APP_DIR!\!APP_EXE!"

if exist "!APP_PATH!" (
    echo Starting ok-ww...
    pushd "!APP_DIR!"
    start "" "!APP_EXE!" -t 1 -e
    if !errorlevel!==0 (
        echo [%time%] ok-ww.exe started successfully.
    ) else (
        echo [%time%] [ERROR] ok-ww.exe failed to start, error code: !errorlevel!
        popd
        exit /b 1
    )
    popd
) else (
    echo [%time%] [ERROR] File not found: "!APP_PATH!"
    echo Please check the installation path in task_4_okww.bat.
    exit /b 1
)

exit /b 0