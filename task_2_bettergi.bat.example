@echo off
setlocal EnableDelayedExpansion
title Launch BetterGI

echo [%time%] [Task 2/4] Launching BetterGI.exe (Parameter: startOneDragon)
REM ========================================================
REM CONFIGURATION REQUIRED
REM Please set APP_DIR to the directory where BetterGI.exe is installed.
REM Example: set "APP_DIR=C:\Program Files\BetterGI"
REM ========================================================
set "APP_DIR=YOUR_INSTALLATION_PATH_HERE"
set "APP_EXE=BetterGI.exe"
set "APP_PATH=!APP_DIR!\!APP_EXE!"

if exist "!APP_PATH!" (
    echo Starting BetterGI...
    start "" /d "!APP_DIR!" "!APP_PATH!" startOneDragon
    if !errorlevel!==0 (
        echo [%time%] BetterGI.exe started successfully.
    ) else (
        echo [%time%] [ERROR] BetterGI.exe failed to start, error code: !errorlevel!
        exit /b 1
    )
) else (
    echo [%time%] [ERROR] File not found: "!APP_PATH!"
    echo Please check the installation path in task_2_bettergi.bat.
    exit /b 1
)

exit /b 0